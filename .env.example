# ──────────────────────────────────────────────
# Groq (Free tier — ultra fast, no billing needed)
# Get key: https://console.groq.com  → API Keys → Create API Key
# ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────
# Twilio WhatsApp
# Console: https://console.twilio.com
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Sandbox number (leave as-is for sandbox):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number (include country code, e.g. +91 for India):
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ──────────────────────────────────────────────
# NewsAPI (Free: 100 req/day)
# Get key: https://newsapi.org/register
# ──────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ──────────────────────────────────────────────
# Cloudinary (Free: 25GB storage)
# Dashboard: https://cloudinary.com/console
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ──────────────────────────────────────────────
# Server (set automatically by Railway/Render)
# ──────────────────────────────────────────────
PORT=8080
